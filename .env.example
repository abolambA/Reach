# ============================================================
# REQUIRED — Supabase (new key format: sb_publishable_*, sb_secret_*)
# ============================================================

# Project URL — Supabase Dashboard → Settings → API → "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (replaces "anon key") — safe to expose, used client-side
# Supabase Dashboard → Settings → API Keys → publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (replaces "service_role key") — SERVER ONLY, never expose
# Supabase Dashboard → Settings → API Keys → secret key
SUPABASE_SECRET_KEY=sb_secret_...

# ============================================================
# REQUIRED — Gemini (Google AI Studio)
# ============================================================
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ============================================================
# REQUIRED — site URL
# ============================================================
# Locally: http://localhost:3000
# In production: your Vercel URL or custom domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# OPTIONAL — Unipile (only for live LinkedIn sync, paid)
# ============================================================
UNIPILE_API_KEY=
UNIPILE_DSN=

# ============================================================
# OPTIONAL — auth allowlist (recommended for production)
# ============================================================
# Comma-separated list of emails allowed to sign in.
# Leave blank to allow any email with a valid magic link.
ALLOWED_EMAILS=
