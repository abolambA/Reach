# ============================================================
# REQUIRED — Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ============================================================
# REQUIRED — Gemini
# ============================================================
GEMINI_API_KEY=AIza...

# ============================================================
# REQUIRED — site URL
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# REQUIRED for v2 — Chrome extension auth token
# ============================================================
# Random string. The Chrome extension sends this in the Authorization
# header so randos can't hit /api/extension/*. Generate one with:
#   openssl rand -hex 32
REACH_INGEST_TOKEN=

# ============================================================
# OPTIONAL — Unipile
# ============================================================
UNIPILE_API_KEY=
UNIPILE_DSN=
